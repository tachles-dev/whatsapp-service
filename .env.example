# Server
PORT=3000
HOST=0.0.0.0

# Security
API_KEY=your-secret-api-key-here

# Redis
REDIS_URL=redis://localhost:6379

# WhatsApp Auth Storage (Render Persistent Disk)
AUTH_DIR=/data/auth

# Webhook - Next.js Backend
WEBHOOK_URL=https://your-nextjs-app.vercel.app/api/whatsapp/webhook
WEBHOOK_API_KEY=your-webhook-secret-key

# Allowed contacts (comma-separated JIDs)
# e.g. 972501234567@s.whatsapp.net,120363012345678901@g.us
ALLOWED_CONTACTS=

# Heartbeat interval in ms (default: 5 minutes)
HEARTBEAT_INTERVAL=300000
