# .env.example — copy to .env and fill in every value before first deploy.
#
# Generate secrets:   openssl rand -hex 32

# ── Domain & TLS (Caddy) ──────────────────────────────────────────────────────
# The public hostname Caddy will obtain a Let's Encrypt certificate for.
DOMAIN=wa.tachles.dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── API auth ──────────────────────────────────────────────────────────────────
# Master key — full access to all endpoints and the admin dashboard.
# Must also be set as WGS_MASTER_KEY in your Next.js app.
API_KEY=change-me-use-openssl-rand-hex-32

# HMAC secret used to hash per-client API keys before storing in Redis.
# Changing this invalidates all existing client keys. Never expose this value.
KEY_SECRET=change-me-use-openssl-rand-hex-32

# Optional control-plane guard for master-key API calls.
# If set, any request using API_KEY must also send this header value.
# This is the recommended way to ensure only your external provisioning service
# can perform cloud control actions with the master key.
# CONTROL_PLANE_SECRET=change-me-use-openssl-rand-hex-32
# CONTROL_PLANE_HEADER=x-control-plane-key
# Optional comma-separated IP allowlist for master-key callers.
# CONTROL_PLANE_ALLOWED_IPS=203.0.113.10,198.51.100.20

# ── Redis ─────────────────────────────────────────────────────────────────────
# Password used by both the Redis server (--requirepass) and the app client URL.
# Keep REDIS_PASSWORD and the password inside REDIS_URL identical.
REDIS_PASSWORD=change-me-use-openssl-rand-hex-32
REDIS_URL=redis://:change-me-use-openssl-rand-hex-32@redis:6379

# ── Webhook delivery ──────────────────────────────────────────────────────────
# URL that receives inbound WhatsApp events (POST with JSON body).
WEBHOOK_URL=https://your-nextjs-app.vercel.app/api/webhooks/whatsapp
# Shared secret validated by the Next.js handler — must match WGS_WEBHOOK_SECRET.
WEBHOOK_API_KEY=change-me-use-openssl-rand-hex-32

# ── Module loading ────────────────────────────────────────────────────────────
# Choose one built-in runtime profile: lite, standard, full.
MODULE_PROFILE=standard
# Or point to your own JSON file such as ./config/modules.custom.json
# MODULE_CONFIG_PATH=./config/modules.custom.json

# Per-module overrides (optional)
# MODULE_ADMIN_ENABLED=false
# MODULE_AUDIT_ENABLED=false
# MODULE_HEARTBEAT_ENABLED=false
# MODULE_WEBHOOKS_ENABLED=true
# MODULE_SCHEDULING_ENABLED=true
# MODULE_MULTI_INSTANCE_LEASING_ENABLED=false
# MODULE_OWNER_FORWARDING_ENABLED=false

# Multi-instance routing (required only when owner forwarding is enabled)
# INSTANCE_BASE_URL=https://wgs-instance-1.internal.example.com

# ── WhatsApp auth storage ─────────────────────────────────────────────────────
# Maps to the auth_data Docker volume. Do not change unless you remap the volume.
AUTH_BASE_DIR=/data/auth

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# Heartbeat interval in ms (default: 5 minutes).
HEARTBEAT_INTERVAL=300000

# Outbound send quotas (per rolling window)
SEND_THROTTLE_WINDOW_MS=60000
CLIENT_SENDS_PER_WINDOW=300
DEVICE_SENDS_PER_WINDOW=120
BROADCAST_MAX_CONCURRENCY=5

# Admin dashboard session auth
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# Comma-separated JIDs/phones allowed to receive messages (blank = no restriction).
ALLOWED_CONTACTS=

# SOCKS5 proxy for outbound WhatsApp Web traffic (leave blank to disable).
# PROXY_URL=socks5://user:pass@proxy.host:1080
