# .env.example — copy to .env and fill in every value before first deploy.
#
# Generate secrets:   openssl rand -hex 32

# ── Domain & TLS (Caddy) ──────────────────────────────────────────────────────
# The public hostname Caddy will obtain a Let's Encrypt certificate for.
DOMAIN=wa.tachles.dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── API auth ──────────────────────────────────────────────────────────────────
# Master key — full access to all endpoints and the admin dashboard.
# Must also be set as WGS_API_KEY in your Next.js app.
API_KEY=change-me-use-openssl-rand-hex-32

# HMAC secret used to hash per-client API keys before storing in Redis.
# Changing this invalidates all existing client keys. Never expose this value.
KEY_SECRET=change-me-use-openssl-rand-hex-32

# ── Redis ─────────────────────────────────────────────────────────────────────
# Password used by both the Redis server (--requirepass) and the app client URL.
# Keep REDIS_PASSWORD and the password inside REDIS_URL identical.
REDIS_PASSWORD=change-me-use-openssl-rand-hex-32
REDIS_URL=redis://:change-me-use-openssl-rand-hex-32@redis:6379

# ── Webhook delivery ──────────────────────────────────────────────────────────
# URL that receives inbound WhatsApp events (POST with JSON body).
WEBHOOK_URL=https://your-nextjs-app.vercel.app/api/webhooks/whatsapp
# Shared secret validated by the Next.js handler — must match WGS_WEBHOOK_SECRET.
WEBHOOK_API_KEY=change-me-use-openssl-rand-hex-32

# ── WhatsApp auth storage ─────────────────────────────────────────────────────
# Maps to the auth_data Docker volume. Do not change unless you remap the volume.
AUTH_BASE_DIR=/data/auth

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# Heartbeat interval in ms (default: 5 minutes).
HEARTBEAT_INTERVAL=300000

# Comma-separated JIDs/phones allowed to receive messages (blank = no restriction).
ALLOWED_CONTACTS=

# SOCKS5 proxy for outbound WhatsApp Web traffic (leave blank to disable).
# PROXY_URL=socks5://user:pass@proxy.host:1080
